<head>
  <title><%= content_for(:title) || product_name %></title>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

  <%= combobox_style_tag %>

  <%= javascript_importmap_tags %>
  <%= render "layouts/dark_mode_check" %>
  <%= render "layouts/privacy_mode_check" %>
  <%= turbo_refreshes_with method: :morph, scroll: :preserve %>

  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover">

  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="<%= product_name %>">
  <meta name="color-scheme" content="dark light">

  <%# Use theme colors that match both light and dark modes %>
  <meta name="msapplication-TileColor" content="#0B0B0B">
  <meta name="theme-color" content="#F9F9F9" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#0B0B0B" media="(prefers-color-scheme: dark)">

  <link rel="manifest" href="<%= pwa_manifest_path %>">
  <%# Provide multiple iOS icons (standard 180x180 and larger) %>
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="apple-touch-icon" sizes="512x512" href="/logo-pwa.png">
  <link rel="icon" sizes="192x192" type="image/png" href="/android-chrome-192x192.png">

  <% if Rails.env.production? && (posthog_config = Rails.configuration.x.posthog).try(:api_key).present? %>
    <%= render "shared/posthog", posthog_api_key: posthog_config.api_key, posthog_host: posthog_config.host %>
  <% end %>

  <%= yield :head %>
  <script>
    function brandfetchFallback(img) {
      var src = img.src || '';
      var m = src.match(/cdn\.brandfetch\.io\/([^\/]+)\/(icon|symbol|logo)\/fallback\/404\/w\/(\d+)\/h\/(\d+)\?c=([^&]+)/);
      if (m) {
        var domain = m[1], type = m[2], w = m[3], h = m[4], c = m[5];
        var next = { icon: 'symbol', symbol: 'logo' }[type];
        if (next) {
          img.src = 'https://cdn.brandfetch.io/' + domain + '/' + next + '/fallback/404/w/' + w + '/h/' + h + '?c=' + c;
        } else {
          img.src = 'https://cdn.brandfetch.io/' + domain + '/theme/light/logo/fallback/404/w/' + w + '/h/' + h + '?c=' + c;
        }
        return;
      }
      var mt = src.match(/cdn\.brandfetch\.io\/([^\/]+)\/theme\/(light|dark)\/logo\/fallback\/404\/w\/(\d+)\/h\/(\d+)\?c=([^&]+)/);
      if (mt) {
        var domain = mt[1], theme = mt[2], w = mt[3], h = mt[4], c = mt[5];
        if (theme === 'light') {
          img.src = 'https://cdn.brandfetch.io/' + domain + '/theme/dark/logo/fallback/404/w/' + w + '/h/' + h + '?c=' + c;
        } else {
          img.onerror = null;
          var initials = (img.alt || '').split(/\s+/).filter(Boolean).slice(0, 2).map(function(word) { return word[0] || ''; }).join('').toUpperCase() || '?';
          var svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ' + w + ' ' + h + '"><rect width="100%" height="100%" fill="#e5e7eb" rx="' + Math.round(parseInt(w) / 4) + '"/><text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" font-family="ui-sans-serif,system-ui,sans-serif" font-size="' + Math.round(parseInt(w) * 0.4) + '" font-weight="600" fill="#6b7280">' + initials + '</text></svg>';
          img.src = 'data:image/svg+xml,' + encodeURIComponent(svg);
        }
        return;
      }
      img.onerror = null;
    }
  </script>
</head>
