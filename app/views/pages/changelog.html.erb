<%= content_for :page_title, t(".title") %>

<div class="bg-container shadow-border-xs rounded-xl p-4 grow overflow-y-auto">
  <% if @changelog_entries.present? %>
    <%# WillBudget-specific changelog from billing service %>
    <% latest = @changelog_entries.first %>
    <div class="mb-6">
      <div class="flex items-center gap-2 mb-1">
        <span class="text-xs font-mono bg-surface px-2 py-0.5 rounded text-secondary"><%= latest["version"] %></span>
        <span class="text-xs text-secondary"><%= Date.parse(latest["published_at"]).strftime("%B %d, %Y") rescue "Recently" %></span>
      </div>
      <h2 class="text-xl font-semibold text-primary mb-3"><%= latest["title"] %></h2>
      <% if latest["summary"].present? %>
        <p class="text-secondary text-sm mb-4"><%= latest["summary"] %></p>
      <% end %>
      <% if latest["content"].present? %>
        <%
          markdown = Redcarpet::Markdown.new(Redcarpet::Render::HTML, autolink: true, tables: true, fenced_code_blocks: true, strikethrough: true)
          rendered = markdown.render(latest["content"])
        %>
        <div class="text-secondary text-sm prose prose--github-release-notes">
          <%= rendered.html_safe %>
        </div>
      <% end %>
      <% if latest["commit_from"].present? && latest["commit_to"].present? %>
        <div class="mt-4">
          <%= link_to "View all changes on GitHub →",
                "https://github.com/Artifrack/WillBudget-Sure/compare/#{latest["commit_from"]}...#{latest["commit_to"]}",
                target: "_blank", rel: "noopener noreferrer",
                class: "text-xs text-accent hover:underline" %>
        </div>
      <% end %>
    </div>

    <div class="border-t border-alpha-black-10 pt-4">
      <%= link_to changelog_history_path,
            class: "inline-flex items-center gap-1.5 text-sm text-accent hover:underline" do %>
        All updates
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
          <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 0 1 .02-1.06L11.168 10 7.23 6.29a.75.75 0 1 1 1.04-1.08l4.5 4.25a.75.75 0 0 1 0 1.08l-4.5 4.25a.75.75 0 0 1-1.06-.02Z" clip-rule="evenodd" />
        </svg>
      <% end %>
    </div>

  <% else %>
    <%# Fallback: upstream GitHub release notes %>
    <div class="flex flex-col md:flex-row justify-between gap-4 mb-12 last:mb-0">
      <div class="w-full md:w-1/3">
        <div class="md:px-3 flex items-center gap-3">
          <% if @release_notes[:avatar].present? %>
            <div class="text-inverse shrink-0 w-9 h-9">
              <%= image_tag @release_notes[:avatar], class: "rounded-full w-full h-full object-cover" %>
            </div>
          <% else %>
            <div class="bg-gray-300 text-gray-600 shrink-0 w-9 h-9 rounded-full flex items-center justify-center text-sm font-medium">
              <%= @release_notes[:username]&.first&.upcase || "?" %>
            </div>
          <% end %>
          <div>
            <a class="text-primary font-medium text-sm" href="https://github.com/<%= @release_notes[:username] %>"><%= "@#{@release_notes[:username]}" %></a>
            <div class="text-secondary text-sm"><%= @release_notes[:published_at]&.strftime("%B %d, %Y") || "Date unavailable" %></div>
          </div>
        </div>
      </div>
      <div class="w-full md:w-2/3 text-secondary text-sm prose prose--github-release-notes">
        <h2 class="mb-5 text-xl text-primary"><%= @release_notes[:name] %></h2>
        <%= (@release_notes[:body] || "No release notes available").html_safe %>
      </div>
    </div>
  <% end %>
</div>
