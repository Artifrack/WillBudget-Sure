<%= render DS::Dialog.new do |dialog| %>
  <% dialog.with_header(title: t(".title")) %>
  <% dialog.with_body do %>
    <% if @family_merchant.is_a?(ProviderMerchant) %>
      <div class="bg-amber-50 border border-amber-200 rounded-lg px-3 py-2 mb-4 text-xs text-amber-800">
        <strong>Note:</strong> Changing this merchant's name will create a personal copy for your account only — your transactions will be redirected to the new merchant.
      </div>
    <% end %>
    <%= render "form", family_merchant: @family_merchant %>
    <% if @family_merchant.is_a?(ProviderMerchant) %>
      <div class="mt-4 pt-4 border-t border-secondary">
        <p class="text-xs font-medium text-primary mb-2">Suggest a better logo</p>
        <p class="text-xs text-subdued mb-3">See a missing or poor-quality logo? Upload a replacement for admin review.</p>
        <div id="suggest-logo-preview" class="mb-3 hidden">
          <img id="suggest-logo-img" src="" alt="" class="w-14 h-14 rounded-full object-contain border border-secondary bg-white">
        </div>
        <label class="inline-flex items-center gap-2 cursor-pointer text-xs px-3 py-1.5 rounded-lg border border-secondary bg-container text-primary hover:bg-container-inset transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
          Choose image
          <input type="file" accept="image/*" class="hidden" onchange="handleLogoSuggestion(this, '<%= @family_merchant.id %>')">
        </label>
        <span id="suggest-logo-msg" class="text-xs ml-2"></span>
      </div>
      <script>
        function handleLogoSuggestion(input, merchantId) {
          var file = input.files[0];
          if (!file) return;
          var reader = new FileReader();
          reader.onload = function(e) {
            var img = new Image();
            img.onload = function() {
              var canvas = document.createElement('canvas');
              canvas.width = 120; canvas.height = 120;
              var ctx = canvas.getContext('2d');
              var s = Math.min(img.width, img.height);
              var ox = (img.width - s) / 2, oy = (img.height - s) / 2;
              ctx.drawImage(img, ox, oy, s, s, 0, 0, 120, 120);
              var dataUrl = canvas.toDataURL('image/png');
              var preview = document.getElementById('suggest-logo-img');
              var wrap = document.getElementById('suggest-logo-preview');
              if (preview) { preview.src = dataUrl; wrap.classList.remove('hidden'); }
              submitLogoSuggestion(merchantId, dataUrl);
            };
            img.src = e.target.result;
          };
          reader.readAsDataURL(file);
        }
        async function submitLogoSuggestion(merchantId, imageData) {
          var msgEl = document.getElementById('suggest-logo-msg');
          msgEl.textContent = 'Submitting…';
          msgEl.className = 'text-xs ml-2 text-subdued';
          try {
            var resp = await fetch('/family_merchants/' + merchantId + '/suggest_logo', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content },
              body: JSON.stringify({ image_data: imageData })
            });
            var data = await resp.json();
            if (data.success) {
              msgEl.textContent = 'Submitted for review — thank you!';
              msgEl.className = 'text-xs ml-2 text-green-600';
            } else {
              msgEl.textContent = data.error || 'Submission failed';
              msgEl.className = 'text-xs ml-2 text-red-600';
            }
          } catch(e) {
            msgEl.textContent = e.message;
            msgEl.className = 'text-xs ml-2 text-red-600';
          }
        }
      </script>
    <% end %>
  <% end %>
<% end %>
